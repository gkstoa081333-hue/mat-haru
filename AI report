// netlify/functions/ai-report.js
// 만족도 통계 데이터를 받아 OpenAI API로 결과보고서 초안을 생성합니다.
// OPENAI_API_KEY는 Netlify 대시보드 > Site configuration > Environment variables 에만 등록하세요.
// 클라이언트(index.html)에는 절대 키가 노출되지 않습니다.

export default async (req) => {
  if (req.method !== 'POST') {
    return new Response(JSON.stringify({ error: 'POST만 지원합니다.' }), { status: 405 });
  }

  let body;
  try {
    body = await req.json();
  } catch {
    return new Response(JSON.stringify({ error: '잘못된 요청 형식입니다.' }), { status: 400 });
  }

  const { type, stats } = body || {};
  if (type !== 'satisfaction' || !stats) {
    return new Response(JSON.stringify({ error: '필요한 데이터가 없습니다.' }), { status: 400 });
  }

  const apiKey = process.env.OPENAI_API_KEY;
  if (!apiKey) {
    return new Response(JSON.stringify({ error: '서버에 OPENAI_API_KEY가 설정되지 않았습니다.' }), { status: 500 });
  }

  const prompt = buildSatisfactionPrompt(stats);

  try {
    const aiRes = await fetch('https://api.openai.com/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiKey}`,
      },
      body: JSON.stringify({
        model: 'gpt-4o-mini',
        temperature: 0.4,
        messages: [
          {
            role: 'system',
            content: '당신은 대한민국 정신건강복지센터의 사업 결과보고서를 작성하는 실무 담당자입니다. 공공기관 보고서체(개조식 또는 서술식 혼합, 객관적이고 간결한 문장)로 작성합니다. 숫자는 제공된 데이터만 사용하고 임의로 추정하지 않습니다.',
          },
          { role: 'user', content: prompt },
        ],
      }),
    });

    if (!aiRes.ok) {
      const errText = await aiRes.text();
      return new Response(JSON.stringify({ error: 'AI 호출 실패', detail: errText }), { status: 502 });
    }

    const data = await aiRes.json();
    const result = data.choices?.[0]?.message?.content?.trim() || '';
    if (!result) {
      return new Response(JSON.stringify({ error: 'AI가 빈 응답을 반환했습니다.' }), { status: 502 });
    }

    return new Response(JSON.stringify({ result }), {
      status: 200,
      headers: { 'Content-Type': 'application/json' },
    });
  } catch (err) {
    return new Response(JSON.stringify({ error: '서버 오류', detail: err.message }), { status: 500 });
  }
};

function buildSatisfactionPrompt(stats) {
  const { target, volunteer, programName } = stats;

  const targetLines = (target.itemLabels || [])
    .map((label, i) => `- ${label}: 평균 ${target.itemAverages?.[i] ?? '-'} / 5`)
    .join('\n');

  const volLines = (volunteer.itemLabels || [])
    .map((label, i) => `- ${label}: 평균 ${volunteer.itemAverages?.[i] ?? '-'} / 5`)
    .join('\n');

  return `'${programName}' 사업의 만족도 조사 결과보고서 초안을 작성해주세요.

[대상자(참여자) 만족도]
- 응답 인원: ${target.count}명
${targetLines || '(문항 데이터 없음)'}
- 센터 사전 인지율: ${target.knownCenterPct != null ? target.knownCenterPct + '%' : '데이터 없음'}
- 주요 서술형 의견(일부): ${target.comments?.length ? target.comments.join(' / ') : '없음'}

[자원봉사자 만족도]
- 응답 인원: ${volunteer.count}명
${volLines || '(문항 데이터 없음)'}
- 주요 서술형 의견(일부): ${volunteer.comments?.length ? volunteer.comments.join(' / ') : '없음'}

작성 지침:
1. "1. 조사 개요 / 2. 조사 결과 / 3. 종합 의견 및 향후 계획" 구조로 작성
2. 조사 결과는 대상자·자원봉사자를 구분해서 서술하고, 위에 제시된 평균 수치를 정확히 인용
3. 응답 인원이 0명인 항목은 "해당 없음"으로 명시하고 억지로 서술하지 말 것
4. 종합 의견은 수치에 근거해 2~3문장으로 간결하게, 향후 계획은 개선 방향 1~2가지 제안
5. 공공기관 보고서 문체(음슴체 또는 정중한 서술체 통일), 과장된 표현 지양`;
}
